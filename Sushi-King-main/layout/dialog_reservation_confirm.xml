<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFF8F0">

    <!-- CONFIRM SECTION -->
    <LinearLayout
        android:id="@+id/layoutConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E31E24"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="📅"
                android:textSize="26sp"
                android:gravity="center"
                android:background="@drawable/bg_white_rounded"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Reservation"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Please check your booking details"
                android:textSize="12sp"
                android:textColor="#FFCCCC"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="20sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textSize="11sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvConfirmDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="15sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕐" android:textSize="20sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time" android:textSize="11sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvConfirmTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="15sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="12dp" android:background="#FFFFFF" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="20sp" android:layout_marginEnd="12dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No. of Pax" android:textSize="11sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvConfirmPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="15sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmNo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Go Back"
                    android:textColor="#E31E24"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="#FFFFFF"
                    app:strokeColor="#E31E24"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirmYes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Confirm ✅"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#E31E24"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- SUCCESS SECTION (hidden at first) -->
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Success Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#064E3B"
            android:padding="24dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:text="🎉"
                android:textSize="30sp"
                android:gravity="center"
                android:background="@drawable/bg_white_rounded"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Booking Confirmed!"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="We look forward to seeing you!"
                android:textSize="12sp"
                android:textColor="#A7F3D0"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Booking ID -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0FDF4">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Booking ID" android:textSize="11sp" android:textColor="#9CA3AF" android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvSuccessId" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ABC12345" android:textSize="22sp" android:textStyle="bold" android:textColor="#064E3B" android:letterSpacing="0.1"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📅" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date" android:textSize="10sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvSuccessDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🕐" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Time" android:textSize="10sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvSuccessTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="10dp" android:background="#FFFFFF" android:layout_marginBottom="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="18sp" android:layout_marginEnd="10dp"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No. of Pax" android:textSize="10sp" android:textColor="#9CA3AF"/>
                    <TextView android:id="@+id/tvSuccessPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="14sp" android:textStyle="bold" android:textColor="#1F2937"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 View in Profile → My Reservations"
                android:textSize="11sp"
                android:textColor="#6B7280"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSuccessOk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Done 🎉"
                android:textColor="#FFFFFF"
                app:backgroundTint="#064E3B"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
