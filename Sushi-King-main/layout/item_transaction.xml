<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingTop="32dp">

        <!-- Top row: ID + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvTransId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="#ABC12345"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1F2937"/>

            <TextView
                android:id="@+id/tvTransAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RM20.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E31E24"/>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:id="@+id/tvTransDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Date"
            android:textSize="13sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="4dp"/>

        <!-- Items -->
        <TextView
            android:id="@+id/tvTransItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No pre-ordered food"
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:layout_marginBottom="8dp"/>

        <!-- Bottom row: Status + Receipt button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTransStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✅ Completed"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#22C55E"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewReceipt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧾 Receipt"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#E31E24"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
