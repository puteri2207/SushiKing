<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#E31E24"
            android:padding="20dp"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="💳"
                android:textSize="26sp"
                android:gravity="center"
                android:background="@drawable/bg_white_rounded"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure payment for your reservation"
                android:textSize="12sp"
                android:textColor="#FFCCCC"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <!-- Booking Summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F9FAFB">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Booking Summary" android:textSize="14sp" android:textStyle="bold" android:textColor="#1F2937" android:layout_marginBottom="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Date" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvPaymentDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="13sp" android:textStyle="bold" android:textColor="#1F2937"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Time" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvPaymentTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="13sp" android:textStyle="bold" android:textColor="#1F2937"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pax" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvPaymentPax" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--" android:textSize="13sp" android:textStyle="bold" android:textColor="#1F2937"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E5E7EB" android:layout_marginVertical="8dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Deposit" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvPaymentDeposit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RM0.00" android:textSize="13sp" android:textColor="#1F2937"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Food Order" android:textSize="13sp" android:textColor="#6B7280"/>
                        <TextView android:id="@+id/tvPaymentFood" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RM0.00" android:textSize="13sp" android:textColor="#1F2937"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="TOTAL" android:textSize="15sp" android:textStyle="bold" android:textColor="#1F2937"/>
                        <TextView android:id="@+id/tvPaymentTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RM0.00" android:textSize="15sp" android:textStyle="bold" android:textColor="#E31E24"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Details -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Card Details" android:textSize="15sp" android:textStyle="bold" android:textColor="#1F2937" android:layout_marginBottom="12dp"/>

            <!-- Card Number with format hint -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Card Number"
                style="@style/InputField"
                android:layout_marginBottom="10dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCardNumber"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="19"
                    android:textColor="#1F2937"
                    android:letterSpacing="0.1"
                    android:hint="1234 5678 9012 3456"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cardholder Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Cardholder Name"
                style="@style/InputField"
                android:layout_marginBottom="10dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCardName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="#1F2937"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Expiry + CVV -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="MM/YY"
                    style="@style/InputField"
                    android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="5"
                        android:textColor="#1F2937"
                        android:hint="12/28"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="CVV"
                    style="@style/InputField">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCvv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLength="3"
                        android:textColor="#1F2937"
                        android:hint="123"/>
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelPayment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="#E31E24"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="#FFFFFF"
                    app:strokeColor="#E31E24"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="12dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPayNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pay Now 💳"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="#E31E24"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
