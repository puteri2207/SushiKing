<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SushiKing">

        <activity
            android:name=".ActivitySplash"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".LoginChoice" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".CustomerLogin" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".CustomerSignup" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".StaffLogin" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".StaffSignUp" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".CustomerMain" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ShowQrActivity" android:exported="false"/>
        <activity android:name=".MenuActivity" android:exported="false"/>
        <activity android:name=".PromoActivity" android:exported="false"/>
        <activity android:name=".CustomerReservationActivity" android:exported="false"/>
        <activity android:name=".StaffMain" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".StaffMenuActivity" android:exported="false" android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".StaffReservationActivity" android:exported="false"/>
        <activity android:name=".StoreLocatorActivity" android:exported="false"/>
        <activity android:name=".ThemeActivity" android:exported="false"/>
        <activity android:name=".TransactionHistoryActivity" android:exported="false"/>
        <activity android:name=".PreOrderActivity" android:exported="false"/>

    </application>
</manifest>
